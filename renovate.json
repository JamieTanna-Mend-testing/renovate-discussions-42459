{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:best-practices"
	],
	"packageRules": [
		{
			"description": "Ensure source compatibility with Go version used by this project",
			"matchDatasources": [
				"go"
			],
			"constraintsFiltering": "strict",
			"constraints": {
				"go": "1.24.0"
			}
		}
	]
}
